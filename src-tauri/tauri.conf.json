{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pantry Pal",
  "version": "0.3.0",
  "identifier": "com.ainadara.pantrypal",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pantry Pal",
        "width": 1100,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#faf5ed"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
